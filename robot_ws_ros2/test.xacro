  <gazebo reference="lidar2_link">
    <!-- Gazebo is unable to use the same <material> tags that are already in the URDF (that RViz uses). -->
    <!-- Instead, we need to add gazebo tags for our links that refer to Gazebo materials -->
    <material>Gazebo/Orange</material>
    <sensor name="lidar2" type="ray">
      <!--use "gpu_ray" instead of "ray" only when having a dedicated gpu-->
      <!--<pose>0 0 0.0225 0 0 0</pose> (seems to be ignored)-->
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>10.0</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1.000000</resolution>
            <min_angle>3.14159265359</min_angle>
            <!-- Set to π for 180 degrees  = to simulate RPlidars (We need to shift all values according to rpLidars)-->
            <max_angle>9.424777960770001</max_angle>
            <!-- Set to 3π for keeping 360 degres range -->
          </horizontal>
        </scan>
        <range>
          <min>0.07</min>
          <max>12.0</max>
          <resolution>0.015000</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <plugin filename="libgazebo_ros_ray_sensor.so" name="lidar2_scan">
        <ros>
          <remapping>~/out:=lidar2/scan</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>lidar2_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>
